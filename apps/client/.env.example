# Frontend env vars must be prefixed with VITE_ to be exposed to the client.
# Leave empty to use the same-origin /api proxy in dev.
VITE_API_BASE_URL=

# ─── Firebase (Phase 4 — Phone sign-up) ───────────────────────────────────
# Get these from your Firebase project console → Project settings → Your apps
# If left empty, phone sign-up will show a "Firebase not configured" message.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
