# ─── Server ───────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Comma-separated list of allowed origins for CORS in production.
# In development, Replit dev domains (.replit.dev) and localhost are allowed
# automatically.
CORS_ORIGIN=

# ─── Database (Phase 1+) ──────────────────────────────────────────────────
# Neon Postgres connection string (you provision this yourself on neon.com).
# Format: postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=

# ─── Auth secrets (Phase 1+) ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
REFRESH_TOKEN_SECRET=
# HMAC pepper used to hash email/phone identifiers before storage.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IDENTIFIER_HMAC_PEPPER=

# ─── Email OTP (Phase 1+) ─────────────────────────────────────────────────
# Resend API key for sending OTP emails (free tier: 3,000/mo).
# If left empty in development, OTPs are printed to the server console
# instead of being emailed — useful for local testing.
RESEND_API_KEY=
# "From" address Resend will send as. Must be on a verified domain in Resend
# (or use Resend's onboarding@resend.dev for testing).
RESEND_FROM=Veil <onboarding@resend.dev>

# ─── Firebase Admin (Phase 4 — Phone sign-up) ─────────────────────────────
# Firebase Admin SDK credentials — from Firebase console → Service accounts.
# If all three are left empty, phone sign-up returns a PRECONDITION_FAILED
# error with a clear message pointing here.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# The private key is multi-line. Paste it as a single string with literal \n:
# e.g. "-----BEGIN PRIVATE KEY-----\nMIIEvQ....\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# ─── Cookies ──────────────────────────────────────────────────────────────
# Set to "true" in production behind HTTPS. Auto-detected from NODE_ENV.
COOKIE_SECURE=
