# Server configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Comma-separated list of allowed origins for CORS in production
# In development, the Replit dev domain is allowed automatically.
CORS_ORIGIN=

# === Phase 1+ secrets (not used yet, listed for reference) ===
# DATABASE_URL=                # Neon Postgres (you provide this yourself)
# REDIS_URL=                   # Upstash Redis
# RESEND_API_KEY=              # Email OTP
# JWT_SECRET=
# REFRESH_TOKEN_SECRET=
# IDENTIFIER_HMAC_PEPPER=      # server-side pepper for hashing email/phone
