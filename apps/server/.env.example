# ─── Server ───────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Comma-separated list of allowed origins for CORS in production.
# In development, Replit dev domains (.replit.dev) and localhost are allowed
# automatically.
CORS_ORIGIN=

# ─── Database (Phase 1+) ──────────────────────────────────────────────────
# Neon Postgres connection string (you provision this yourself on neon.com).
# Format: postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=

# ─── Auth secrets (Phase 1+) ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
REFRESH_TOKEN_SECRET=
# HMAC pepper used to hash email/phone identifiers before storage.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IDENTIFIER_HMAC_PEPPER=

# ─── Email OTP (Phase 1+) ─────────────────────────────────────────────────
# Resend API key for sending OTP emails (free tier: 3,000/mo).
# If left empty in development, OTPs are printed to the server console
# instead of being emailed — useful for local testing.
RESEND_API_KEY=
# "From" address Resend will send as. Must be on a verified domain in Resend
# (or use Resend's onboarding@resend.dev for testing).
RESEND_FROM=Veil <onboarding@resend.dev>

# ─── Firebase Admin (Phase 4 — Phone sign-up) ─────────────────────────────
# Firebase Admin SDK credentials — from Firebase console → Service accounts.
# If all three are left empty, phone sign-up returns a PRECONDITION_FAILED
# error with a clear message pointing here.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# The private key is multi-line. Paste it as a single string with literal \n:
# e.g. "-----BEGIN PRIVATE KEY-----\nMIIEvQ....\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# ─── Cookies ──────────────────────────────────────────────────────────────
# Set to "true" in production behind HTTPS. Auto-detected from NODE_ENV.
COOKIE_SECURE=

# ─── Cloudflare R2 (Phase 5 — encrypted media storage) ────────────────────
# Encrypted images, videos and voice notes upload directly from the client
# to R2 via presigned URLs. The server only stores metadata. If any of the
# four below are empty, media endpoints return PRECONDITION_FAILED with a
# clear message listing what's missing.
#
# 1) Create a bucket in Cloudflare → R2 → Create bucket (e.g. "veil-media").
# 2) R2 → Manage R2 API Tokens → Create API token, scope = "Object Read & Write"
#    on that bucket only. Copy the Access Key ID + Secret Access Key.
# 3) Account ID is shown in the right sidebar of the Cloudflare dashboard.
# 4) In the bucket → Settings → CORS Policy, allow PUT and GET from your
#    client origin(s), e.g.:
#    [{"AllowedOrigins":["https://chats-client-vert.vercel.app","http://localhost:5000"],
#      "AllowedMethods":["PUT","GET"],
#      "AllowedHeaders":["content-type"],
#      "ExposeHeaders":["ETag"],"MaxAgeSeconds":3600}]
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Maximum ciphertext size (bytes) the server will sign an upload for.
# Default 16 MB, which comfortably covers a 10 MB photo or short video.
MEDIA_MAX_BYTES=
# How long media stays available before sweeping (hours). Default 24.
MEDIA_TTL_HOURS=
