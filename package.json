{
  "name": "veil",
  "version": "0.0.0",
  "private": true,
  "description": "Veil — private by design. Visible to no one but you.",
  "license": "MIT",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,magenta \"pnpm --filter @veil/client dev\" \"pnpm --filter @veil/server dev\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
